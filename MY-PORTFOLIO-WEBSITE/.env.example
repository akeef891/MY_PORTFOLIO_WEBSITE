# Public site URL for SEO (canonical, Open Graph, sitemap) — no trailing slash
# VITE_SITE_URL=https://your-site.netlify.app

VITE_FIREBASE_API_KEY=your_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_DATABASE_URL=https://your_project-default-rtdb.firebaseio.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# ---------------------------------------------------------------------------
# Netlify Functions ONLY — set in Netlify UI (Site configuration → Environment)
# Do NOT prefix with VITE_ (those are exposed to the browser).
# ---------------------------------------------------------------------------
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxx
# CONTACT_NOTIFY_EMAIL=mdakeef2009@gmail.com
# RESEND_FROM_EMAIL=Portfolio <onboarding@resend.dev>
#
# After deploy, confirm the function exists:
#   https://YOUR-SITE.netlify.app/.netlify/functions/send-contact-email
# (POST only; GET returns 405)
#
# Resend sandbox (onboarding@resend.dev):
#   Delivers only to your Resend account email OR resend test addresses until
#   you verify a custom domain at https://resend.com/domains
#
# Production (recommended):
#   1. Verify your domain in Resend
#   2. RESEND_FROM_EMAIL=Portfolio <noreply@yourdomain.com>
#   3. Redeploy on Netlify
